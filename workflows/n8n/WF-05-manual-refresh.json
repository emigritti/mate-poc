{
  "name": "WF-05 Manual Refresh (Webhook from UI)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "manual-refresh",
        "responseMode": "responseNode"
      },
      "id": "webhook",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "manual-refresh"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {"value1": "={{ $json.body.source_id }}", "operation": "isNotEmpty"}
