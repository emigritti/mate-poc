# ═══════════════════════════════════════════════════════════
# Functional Integration Mate PoC — Environment Template
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# .env is excluded from version control (.gitignore).
# NEVER commit real secrets to this file.

# ── Compose ──────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=integration-mate

# ── Security Middleware ───────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Integration Agent API key (optional — enables auth on mutating endpoints)
# Leave empty to run in unauthenticated PoC mode.
API_KEY=

# ── MongoDB ───────────────────────────────────────────────────
MONGO_HOST=mate-mongodb
MONGO_PORT=27017
MONGO_DB=integration_mate
MONGO_URI=mongodb://mate-mongodb:27017

# ── MinIO / S3 ────────────────────────────────────────────────
S3_ENDPOINT=http://mate-minio:9000
S3_ACCESS_KEY=REPLACE_WITH_MINIO_USER
S3_SECRET_KEY=REPLACE_WITH_MINIO_PASSWORD
S3_REGION=us-east-1
S3_BUCKET_PLM=plm-assets
S3_BUCKET_PIM=pim-media
S3_BUCKET_DAM_ORIGINALS=dam-originals
S3_BUCKET_DAM_RENDITIONS=dam-renditions

# ── Ollama LLM ────────────────────────────────────────────────
OLLAMA_HOST=http://mate-ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ── Service URLs (internal Docker DNS) ───────────────────────
PLM_API_URL=http://mate-plm-mock:3001
PIM_API_URL=http://mate-pim-mock:3002
DAM_API_URL=http://dam-mock:3005
SECURITY_MW_URL=http://security-middleware:3000
ENGINE_URL=http://mate-integration-agent:3003
CATALOG_URL=http://catalog-generator:3004
